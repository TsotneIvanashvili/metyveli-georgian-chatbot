ENVIRONMENT=development

# Local development uses SQLite if DATABASE_URL is empty.
# Render production should use Render Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=

OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
# qwen3.5:397b matches local Ollama's qwen3:8b intent but needs a paid
# Ollama Cloud plan. minimax-m2.5 is free-tier accessible and works well
# for Georgian; see render.yaml for the deployed production value.
OLLAMA_MODEL=minimax-m2.5
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_CONTEXT_SIZE=4096

# For production Render, prefer:
# ALLOWED_ORIGINS=https://your-frontend.onrender.com
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

RAG_TOP_K=4
RAG_MIN_SCORE=0.025
